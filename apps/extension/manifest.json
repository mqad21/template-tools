{
  "manifest_version": 3,
  "name": "Fasih Form Studio Helper",
  "version": "1.0.0",
  "description": "Helper extension for Fasih Form Studio",
  "permissions": ["cookies", "storage", "tabs", "scripting"],
  "host_permissions": [
    "https://fasih-qd.bps.go.id/*",
    "https://fasih-survey.bps.go.id/*"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://fasih-qd.bps.go.id/template/*"],
      "js": ["src/content.ts"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["studio.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
